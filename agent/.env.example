# vpnctl agent configuration
#
# SERVICES - comma-separated list of service types to enable.
#   wg  = built-in WireGuard (requires WG_* vars)
#   awg = script-based AmneziaWG (requires scripts in SCRIPTS_DIR/awg/)
#   vless = script-based VLESS (requires scripts in SCRIPTS_DIR/vless/)
SERVICES=wg

LISTEN_ADDR=0.0.0.0:9000
AGENT_TOKEN=replace-with-random-secret

# WireGuard (required when SERVICES includes 'wg')
WG_INTERFACE=wg0
WG_SUBNET=10.8.0.0/24
WG_ENDPOINT=1.2.3.4:51820
WG_PORT=51820

# Bandwidth fair-share
TOTAL_BANDWIDTH_MBIT=1000
MIN_PER_PEER_MBIT=50
FAIRSHARE_INTERVAL_SEC=120

# Script-based services directory
SCRIPTS_DIR=/opt/vpnbot/scripts

# Watchdog (optional — leave empty to disable)
BOT_TOKEN=
ADMIN_IDS=